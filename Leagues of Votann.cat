            <profile name="Efficient Exemplar" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="af72-23d3-643f-4eab">
              <characteristics>
                <characteristic name="Description" typeId="e24a-6018-20cf-d76c">If a High Kahl (or his unit) destroys a unit with Judgement Tokens, one token may be transferred to a different enemy unit visible to and within 24&quot; of the High Kahl.</characteristic>
              </characteristics>
            </profile>
            <profile name="Kahl wills it!" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="b3ff-078b-e598-573b">
              <characteristics>
                <characteristic name="Description" typeId="e24a-6018-20cf-d76c">During the shooting phase, one friendly Votann unit within 6&quot; of the High Kahl may count their weapons as twin-linked.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
