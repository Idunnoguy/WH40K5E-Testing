    <profile name="Rampart Crest" typeId="456a-26d9-cb27-bd5c" typeName="Wargear" hidden="false" id="c62e-b3e3-3e82-63d6">
      <characteristics>
        <characteristic name="Description" typeId="9e5e-2cfd-7c93-749a">All friendly Votann non-vehicle units within 6&quot; of the bearer gain a 5+ Invulnerable Save against ranged attacks.</characteristic>
      </characteristics>
    </profile>
    <profile name="Teleportation Crest" typeId="456a-26d9-cb27-bd5c" typeName="Wargear" hidden="false" id="defd-93b1-d049-cac4">
      <characteristics>
        <characteristic name="Description" typeId="9e5e-2cfd-7c93-749a">The bearer and any unit it&apos;s attached to gain the Deep Strike Special Rule</characteristic>
      </characteristics>
    </profile>
    <profile name="Weavefield Crest" typeId="456a-26d9-cb27-bd5c" typeName="Wargear" hidden="false" id="6f5d-8b6a-9b42-6c79">
      <characteristics>
        <characteristic name="Description" typeId="9e5e-2cfd-7c93-749a">The bearer gains a 4+ Invulnerable Save</characteristic>
      </characteristics>
    </profile>
