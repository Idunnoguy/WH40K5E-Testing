    <selectionEntry type="unit" import="false" name="Scout Bike Squad" hidden="false" id="6f69-20ed-7de6-cc52" collective="false">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Cluster Mines" hidden="false" id="afea-84f9-4d22-cb76">
          <costs>
            <cost name="Points" typeId="6f18-a8fc-2c5b-9517" value="10"/>
