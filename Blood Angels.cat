            <selectionEntry type="upgrade" import="true" name="Blood Talon" hidden="false" id="94f7-5e09-37d7-8f42">
              <profiles>
                <profile name="Blood Talons" typeId="1d88-1369-f0ed-b39c" typeName="Melee Weapons" hidden="false" id="14fa-55db-ee15-8263">
                  <characteristics>
                    <characteristic name="Ability" typeId="2113-98a2-4376-a94c">Blood Talons follow the rules for Lightning Claws. In addition, if the Dreadnought has two Blood Talons, for every unsaved wound caused with a Blood Talon in close combat, the Dreadnought immediately makes an additional attack. These extra attacks can generate further additional attacks in the same way, until no further unsaved wounds are caused, or all the enemy are slain.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
