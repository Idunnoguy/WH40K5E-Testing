    <profile name="Death Mask" typeId="456a-26d9-cb27-bd5c" typeName="Wargear" hidden="false" id="e1fa-e286-ec6b-6f5e">
      <characteristics>
        <characteristic name="Description" typeId="9e5e-2cfd-7c93-749a">An enemy assaulted by one or more units equipped with Death Masks must pass a Leadership test or be reduced to Weapon skill 1 for the duration of the Assault phase.</characteristic>
      </characteristics>
    </profile>
    <profile name="Frag Cannon" typeId="8e6f-7553-28c5-95a0" typeName="Weapons" hidden="false" id="0ed5-5fe7-6b45-9138">
