            <characteristic name="Sv" typeId="c1e7-f1bd-8acd-7595">2+</characteristic>
          </characteristics>
        </profile>
        <profile name="The Axe Mortalis" typeId="1d88-1369-f0ed-b39c" typeName="Melee Weapons" hidden="false" id="f132-1d05-4b9a-8c25">
          <characteristics>
            <characteristic name="Ability" typeId="2113-98a2-4376-a94c">The Axe Mortalis is a Master-crafted power weapon.</characteristic>
          </characteristics>
        </profile>
        <profile name="Death Mask of Sanguinius" typeId="456a-26d9-cb27-bd5c" typeName="Wargear" hidden="false" id="f523-0abf-e8cc-5afe">
          <characteristics>
            <characteristic name="Description" typeId="9e5e-2cfd-7c93-749a">Before forces are deployed, choose one enemy independent character: that model has -1 Weapon Skill, -1 Wound, -1 Initiative and -1 Attack (all to a minimum of 1) for the remainder of the battle. Additionally, follows the rules for Death Mask.</characteristic>
          </characteristics>
        </profile>
        <profile name="Tactical Precision" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="0072-171e-e435-432e">
          <characteristics>
            <characteristic name="Description" typeId="e24a-6018-20cf-d76c">Commander Dante (and his unit, if he has joined one and they have jump packs) does not scatter when it deploys by Deep Strike.</characteristic>
          </characteristics>
        </profile>
        <profile name="Surgical Strike" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="0cfb-5a8f-e65c-9464">
          <characteristics>
            <characteristic name="Description" typeId="e24a-6018-20cf-d76c">Commander Dante and his unit have the Hit and Run special rule.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Jump Infantry" id="8828-649b-3791-7ab4" hidden="false" type="rule" targetId="4158-c955-9c2f-46f7"/>
