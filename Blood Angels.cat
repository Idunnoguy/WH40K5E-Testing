            <profile name="Liturgies of Blood" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="1787-7e61-f7e3-6de7">
              <characteristics>
                <characteristic name="Description" typeId="e24a-6018-20cf-d76c">On a player turn in which he assaults, this model and all members of any squad he has joined can re-roll failed rolls to hit. Death Company models can also re-roll failed rolls to Wound.</characteristic>
              </characteristics>
            </profile>
            <profile name="The Blood Crozius" typeId="1d88-1369-f0ed-b39c" typeName="Melee Weapons" hidden="false" id="34c9-3dec-6c1a-0827">
              <characteristics>
                <characteristic name="Ability" typeId="2113-98a2-4376-a94c">The Blood Crozius is a master-crafted power weapon.</characteristic>
