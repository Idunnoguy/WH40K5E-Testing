    <selectionEntry type="unit" import="true" name="Chapter Master Gabriel Seth" hidden="false" id="7dbd-119d-aef8-6f74">
      <costs>
        <cost name="Points" typeId="6f18-a8fc-2c5b-9517" value="160"/>
      </costs>
      <profiles>
        <profile name="Gabriel Seth" typeId="0967-823d-dd82-4e47" typeName="Unit" hidden="false" id="1116-d6d7-8063-c9b6">
          <characteristics>
            <characteristic name="WS" typeId="15b1-a34a-6e7c-332e">6</characteristic>
            <characteristic name="BS" typeId="63a5-4be2-9cc0-7723">5</characteristic>
            <characteristic name="S" typeId="09af-e927-0c3c-9d88">4</characteristic>
            <characteristic name="T" typeId="ff29-f8b2-5b20-b686">4</characteristic>
            <characteristic name="W" typeId="4a81-ac45-a71c-c71e">4</characteristic>
            <characteristic name="I" typeId="8517-a46c-d6df-9c75">5</characteristic>
            <characteristic name="A" typeId="a535-0722-3bc1-4d3c">4</characteristic>
            <characteristic name="Ld" typeId="ddd5-77eb-4cc8-9eab">10</characteristic>
            <characteristic name="Sv" typeId="c1e7-f1bd-8acd-7595">3+</characteristic>
          </characteristics>
        </profile>
        <profile name="Blood Reaver" typeId="1d88-1369-f0ed-b39c" typeName="Melee Weapons" hidden="false" id="b72c-c9ff-c9e3-39ed">
          <characteristics>
            <characteristic name="Ability" typeId="2113-98a2-4376-a94c">Blood Reaver is a two-handed weapon. Hits from Blood Reaver are resolved at Strength 8 and have the Rending Special Rule.</characteristic>
          </characteristics>
        </profile>
        <profile name="Whirlwind of Gore" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="57fe-a670-490a-942b">
          <characteristics>
            <characteristic name="Description" typeId="e24a-6018-20cf-d76c">Instead of making his normal attacks, Seth can instead choose to whirl Blood Reaver in a gore-splattered arc. If he does so, Seth inflicts a single automatic hit on all enemy models in base contact. Declare whether or not Seth will perform this attack before any blows are struck.</characteristic>
          </characteristics>
        </profile>
        <profile name="Ferocious Instincts" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="a81e-3c79-3089-9e53">
          <characteristics>
            <characteristic name="Description" typeId="e24a-6018-20cf-d76c">For every roll of &apos;1&apos; to hit against Seth in close combat, enemy units immediately suffer an automatic Strength 4 hit.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="a223-7a5d-784d-2c9c" includeChildSelections="true"/>
      </constraints>
      <infoLinks>
