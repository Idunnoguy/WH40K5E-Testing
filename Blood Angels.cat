        <profile name="The Dead Man&apos;s Hand" typeId="1d88-1369-f0ed-b39c" typeName="Melee Weapons" hidden="false" id="b35a-d2c6-93b5-929f">
          <characteristics>
            <characteristic name="Ability" typeId="2113-98a2-4376-a94c">Tycho&apos;s close combat attacks ignore armour saves and roll an additional D6 for armour penetration. The Dead Man&apos;s Hand also includes a set of digital weapons, allowing Tycho to re-roll a single failed roll to wound each Assault phase.</characteristic>
          </characteristics>
        </profile>
