  <selectionEntries>
    <selectionEntry type="unit" import="true" name="Commander Dante" hidden="false" id="3980-ec5d-2ad8-ff78">
      <costs>
        <cost name="Points" typeId="6f18-a8fc-2c5b-9517" value="225"/>
      </costs>
      <profiles>
        <profile name="Commander Dante" typeId="0967-823d-dd82-4e47" typeName="Unit" hidden="false" id="0c9a-3652-6f12-a365">
          <characteristics>
