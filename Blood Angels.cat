          <profiles>
            <profile name="Cluster Mines" typeId="456a-26d9-cb27-bd5c" typeName="Wargear" hidden="false" id="cca6-4b4d-4db3-3cc6">
              <characteristics>
                <characteristic name="Description" typeId="9e5e-2cfd-7c93-749a">Each Scout Bike Squad equipped with cluster mines can booby-trap one piece of area terrain before the game begins. Note that Scout Bike Squads split into combat squads is still counted as a single squad for the purposes of cluster mines. At the start of the game, after terrain is placed, declare that your Scout Bikers have placed booby-traps and secretly write down the piece(s) of area terrain that have been booby-trapped in this fashion. Each terrain piece can only be booby-trapped once.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="4853-ab41-c27a-75b6"/>
          </constraints>
        </selectionEntry>
      </selectionEntries>
