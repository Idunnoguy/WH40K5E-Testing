          </characteristics>
        </profile>
        <profile name="Bloodstrike Missile" typeId="8e6f-7553-28c5-95a0" typeName="Weapons" hidden="false" id="978e-69a6-6b9c-22da">
          <characteristics>
            <characteristic name="Range" typeId="9b9e-0c24-e409-a801">72&quot;</characteristic>
            <characteristic name="Str." typeId="1ebc-896c-43de-904a">8</characteristic>
            <characteristic name="AP" typeId="730c-47dc-fdad-3c8b">1</characteristic>
            <characteristic name="Type" typeId="1524-30c8-5da7-66ff">Heavy 1, One Shot</characteristic>
            <characteristic name="Notes" typeId="45fd-0f50-e1d0-907c"/>
          </characteristics>
        </profile>
        <profile name="Ceramite Plating" typeId="456a-26d9-cb27-bd5c" typeName="Wargear" hidden="false" id="f8ef-96e0-1f37-4dda">
          <characteristics>
            <characteristic name="Description" typeId="9e5e-2cfd-7c93-749a">Melta weapons do not gain the extra D6 armour penetration when shooting at a Stormraven gunship.</characteristic>
          </characteristics>
        </profile>
        <profile name="Stormraven Gunship" typeId="9a37-e4d2-11fe-9e81" typeName="Transport" hidden="false" id="ebc2-a367-4297-565e">
          <characteristics>
            <characteristic name="Capacity" typeId="7cdf-4c80-a83d-200c">12 models and one Dreadnought.</characteristic>
            <characteristic name="Access Points" typeId="6e42-3bd5-70a6-724f">One on either side.</characteristic>
            <characteristic name="Fire Points" typeId="aa94-ae0c-98e7-5923">-</characteristic>
          </characteristics>
        </profile>
        <profile name="Assault Vehicle" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="9f10-615b-286a-72fe">
          <characteristics>
            <characteristic name="Description" typeId="e24a-6018-20cf-d76c">Models disembarking from any access point on a Stormraven can launch an assault on the turn they do so. (provided the Stormraven did not deep strike)</characteristic>
          </characteristics>
        </profile>
        <profile name="Skies of Blood" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="37b7-1146-2bf3-1e53">
          <characteristics>
            <characteristic name="Description" typeId="e24a-6018-20cf-d76c">If the Stormraven has moved flat out, passengers can still disembark, but they must do so as follows. Nominate any point over which the Stormraven moved over and deploy the squad as if it were deep striking onto that point. If the unit scatters, every model must immediately take a Dangerous Terrain test. Models with jump packs can make a more controlled descent - not only do they not take Dangerous Terrain tests (unless landing on dangerous terrain), they can use the Descent of Angels special rule to make a more accurate landing. If any of the models cannot be deployed, the unit is destroyed as described in the 1-2 result on the Deep Strike Mishap table. Note that models that disembark in this manner cannot assault in the turn they do so.</characteristic>
          </characteristics>
        </profile>
      </profiles>
