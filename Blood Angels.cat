    <selectionEntry type="unit" import="true" name="The Sanguinor" hidden="false" id="7059-14e0-399d-25c2">
      <costs>
        <cost name="Points" typeId="6f18-a8fc-2c5b-9517" value="275"/>
      </costs>
      <profiles>
        <profile name="The Sanguinor" typeId="0967-823d-dd82-4e47" typeName="Unit" hidden="false" id="3570-9065-8858-bb67">
          <characteristics>
            <characteristic name="WS" typeId="15b1-a34a-6e7c-332e">8</characteristic>
