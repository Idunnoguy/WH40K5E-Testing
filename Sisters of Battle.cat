        <infoLink name="Inquisitor Karamazov" id="5317-6c10-b0b4-2c44" hidden="false" type="profile" targetId="44f0-f57c-779a-c48b"/>
        <infoLink name="Master-crafted Multi-melta" id="93c1-eb51-d99e-dea7" hidden="false" type="profile" targetId="5e94-5436-c9b1-c2d2"/>
