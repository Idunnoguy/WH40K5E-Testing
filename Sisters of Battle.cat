              <profiles>
                <profile name="Psychic Beacon" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="cba6-97f3-b5a1-cede">
                  <characteristics>
                    <characteristic name="Description" typeId="e24a-6018-20cf-d76c">If a friendly unit wishes to arrive on the battlefield via Deep Strike and chooses to do so within 6&quot; of a Mystic, then it won&apos;t scatter. Note that the Mystic must already be on the table at the start of the turn for this ability to be used.</characteristic>
