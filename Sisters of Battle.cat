  <rules>
    <rule name="Faith Points" id="04a8-deff-accf-9fe8" hidden="false">
      <description>At the start of each of your Movement phases you generate D6 Faith Points. This is how many Faith Points you have available for the turn; the more available, the more Acts of Faith you will be able to attempt. Any Faith Points that are unused at the end of your turn are lost.</description>
    </rule>
  </rules>
