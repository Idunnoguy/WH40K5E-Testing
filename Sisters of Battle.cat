          <characteristics>
            <characteristic name="Description" typeId="e24a-6018-20cf-d76c">Penitent Engines ignore any crew shaken and crew stunned results on the Vehicle Damage tables.</characteristic>
          </characteristics>
        </profile>
        <profile name="Battle Frenzy" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="3f2d-2e96-72cf-1a40">
          <characteristics>
            <characteristic name="Description" typeId="e24a-6018-20cf-d76c">For every unsaved Wound a Penitent Engine inflicts in close combat, the Penitent Engine immediately makes an additional attack. These extra attacks do not generate further additional attacks in the same way.</characteristic>
          </characteristics>
        </profile>
