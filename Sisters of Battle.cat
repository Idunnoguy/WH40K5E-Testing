    <profile name="Blessed Banner" typeId="456a-26d9-cb27-bd5c" typeName="Wargear" hidden="false" id="e5df-28bd-a4fa-2e0b">
      <characteristics>
        <characteristic name="Description" typeId="9e5e-2cfd-7c93-749a">Any Sisters of Battle unit within 12&quot; of the Banner Bearer re-rolls failed Morale and Pinning tests. In addition, while the Banner Bearer is still alive, the Sororitas Command Squad counts as having scored one extra wound in close combat for the purposes of calculating the assault result.</characteristic>
      </characteristics>
    </profile>
    <profile name="Chirurgeon&apos;s Tools" typeId="456a-26d9-cb27-bd5c" typeName="Wargear" hidden="false" id="a9c3-6660-db2c-1ce6">
      <characteristics>
        <characteristic name="Description" typeId="9e5e-2cfd-7c93-749a">As long as the Sister Hospitaler is alive, her unit has the Feel No Pain special rule.</characteristic>
      </characteristics>
    </profile>
    <profile name="Eviscerator" typeId="1d88-1369-f0ed-b39c" typeName="Melee Weapons" hidden="false" id="eecf-08cc-547c-eaa4">
      <characteristics>
        <characteristic name="Ability" typeId="2113-98a2-4376-a94c">Eviscerators follow all the rules for power fists, and roll an additional D6 for armour penetration.</characteristic>
      </characteristics>
    </profile>
    <profile name="Laud Hailer" typeId="456a-26d9-cb27-bd5c" typeName="Wargear" hidden="false" id="a812-b31f-d861-1ece">
      <characteristics>
        <characteristic name="Description" typeId="9e5e-2cfd-7c93-749a">When any Sisters of Battle unit within 12” of a model with a Laud Hailer successfully makes an Act of Faith, roll a D6 straight away. On a 6, your army immediately gains a single Faith Point.</characteristic>
      </characteristics>
    </profile>
    <profile name="Neural Whip" typeId="1d88-1369-f0ed-b39c" typeName="Melee Weapons" hidden="false" id="fb23-2b1f-b006-af56">
      <characteristics>
        <characteristic name="Ability" typeId="2113-98a2-4376-a94c">Neural whips follow the rules for power weapons. In addition, Hits caused by a neural whip against non-vehicle units strike at Strength 8 and roll To Wound against the opponent’s unmodified Leadership characteristic instead of their Toughness.</characteristic>
      </characteristics>
    </profile>
    <profile name="Simulacrum Imperialis" typeId="456a-26d9-cb27-bd5c" typeName="Wargear" hidden="false" id="ca16-7a34-302f-75c9">
      <characteristics>
        <characteristic name="Description" typeId="9e5e-2cfd-7c93-749a">A unit with a Simulacrum Imperialis re-rolls failed Acts of Faith tests.</characteristic>
      </characteristics>
    </profile>
    <profile name="Shield of Faith" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="35d8-dd34-a92a-42f4">
      <characteristics>
        <characteristic name="Description" typeId="e24a-6018-20cf-d76c">Models with the Shield of Faith special rule have a 6+ invulnerable save.</characteristic>
      </characteristics>
    </profile>
    <profile name="Righteous Rage" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="eec4-5302-648b-bdc9">
      <characteristics>
        <characteristic name="Description" typeId="e24a-6018-20cf-d76c">On a player turn in which a model with this special rule assaults, he and all members of the unit he has joined re-roll failed rolls to hit.</characteristic>
      </characteristics>
    </profile>
