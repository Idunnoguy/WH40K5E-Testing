    <profile name="Hand of the Emperor" typeId="0fe1-877f-d5ab-dcc5" typeName="Act of Faith" hidden="false" id="4be6-513c-896f-7771">
      <characteristics>
        <characteristic name="Ability" typeId="8973-fda0-fb3b-ebce">This Act of Faith is used in the Assault phase. If successful, the unit gains +1 Strength and the Fearless special rule until the end of the phase.</characteristic>
      </characteristics>
    </profile>
