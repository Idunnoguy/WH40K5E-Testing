              <infoLinks>
                <infoLink name="Inquisitor Servitor" id="2e09-b6c2-4c3e-80b6" hidden="false" type="profile" targetId="17fe-3752-3577-8173"/>
                <infoLink name="Servo-arm" id="15a2-6a76-2cc9-7c94" hidden="false" type="profile" targetId="3bb0-d10e-9059-eb84"/>
