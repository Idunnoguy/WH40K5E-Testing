            <selectionEntry type="model" import="true" name="Daemonhost" hidden="false" id="8925-f9c6-d363-ad29" sortIndex="3">
              <costs>
                <cost name="Points" typeId="6f18-a8fc-2c5b-9517" value="10"/>
