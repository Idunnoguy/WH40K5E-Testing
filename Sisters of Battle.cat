    <selectionEntry type="unit" import="true" name="Saint Celestine" hidden="false" id="b8f8-69fb-20f4-a644">
      <costs>
        <cost name="Points" typeId="6f18-a8fc-2c5b-9517" value="115"/>
      </costs>
      <profiles>
        <profile name="Saint Celestine" typeId="0967-823d-dd82-4e47" typeName="Unit" hidden="false" id="8a19-282e-95be-3ca6">
          <characteristics>
            <characteristic name="WS" typeId="15b1-a34a-6e7c-332e">7</characteristic>
            <characteristic name="BS" typeId="63a5-4be2-9cc0-7723">7</characteristic>
            <characteristic name="S" typeId="09af-e927-0c3c-9d88">3</characteristic>
            <characteristic name="T" typeId="ff29-f8b2-5b20-b686">3</characteristic>
            <characteristic name="W" typeId="4a81-ac45-a71c-c71e">3</characteristic>
            <characteristic name="I" typeId="8517-a46c-d6df-9c75">7</characteristic>
            <characteristic name="A" typeId="a535-0722-3bc1-4d3c">5</characteristic>
            <characteristic name="Ld" typeId="ddd5-77eb-4cc8-9eab">10</characteristic>
            <characteristic name="Sv" typeId="c1e7-f1bd-8acd-7595">2+ (4+ Invulnerable)</characteristic>
          </characteristics>
        </profile>
        <profile name="Miraculous Intervention" typeId="ccb3-7790-3139-7975" typeName="Abilities" hidden="false" id="d8de-4d5b-ee66-bed0">
          <characteristics>
            <characteristic name="Description" typeId="e24a-6018-20cf-d76c">Every time Celestine is removed as a casualty, place a counter to mark the spot where she ‘died’. Roll a D6 at the start of each of your subsequent turns. If the result is a 4+, place her within 1&quot; of the counter with D3 wounds restored. If Celestine would be placed within 1&quot; of another model, move her by the minimum possible distance so that she is no longer within 1&quot;. Celestine can act normally in a turn in which she ‘resurrects’. Celestine does not award kill points to the enemy if she is alive on the battlefield at the end of the game.</characteristic>
          </characteristics>
        </profile>
        <profile name="The Ardent Blase" typeId="8e6f-7553-28c5-95a0" typeName="Weapons" hidden="false" id="cc64-32ad-430f-b6eb">
          <characteristics>
            <characteristic name="Range" typeId="9b9e-0c24-e409-a801">Template</characteristic>
            <characteristic name="Str." typeId="1ebc-896c-43de-904a">5</characteristic>
            <characteristic name="AP" typeId="730c-47dc-fdad-3c8b">4</characteristic>
            <characteristic name="Type" typeId="1524-30c8-5da7-66ff">Assault 1</characteristic>
            <characteristic name="Notes" typeId="45fd-0f50-e1d0-907c"/>
          </characteristics>
        </profile>
        <profile name="The Ardent Blade" typeId="1d88-1369-f0ed-b39c" typeName="Melee Weapons" hidden="false" id="2020-4c46-405a-fb0a">
          <characteristics>
            <characteristic name="Ability" typeId="2113-98a2-4376-a94c">This is a power weapon that always wounds enemies on a 4+ (unless a lower roll would be required).</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
